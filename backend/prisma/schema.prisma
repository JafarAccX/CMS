// ─── Prisma Schema ───────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  admin
  mentor
  batch_moderator
  learner
  guest
}

enum Provider {
  crm
  website
}

enum SubscriptionStatus {
  free
  active
  expired
}

enum BatchType {
  general
  private
  paid
  public
  hidden
}


enum MembershipRole {
  member
  mentor
  moderator
}

enum MessageType {
  text
  file
  system
}

enum SubPlan {
  free
  pro
}

enum SubStatus {
  active
  expired
  cancelled
}

enum NotificationType {
  new_message
  mention
  admin_action
  mod_action
}

enum ModQueueStatus {
  pending
  resolved
  escalated
}

enum ModQueuePriority {
  low
  medium
  high
}

// ─── Models ──────────────────────────────────────────────────

model User {
  id                  String             @id @default(uuid()) @db.Uuid
  username            String             @unique
  email               String             @unique
  password_hash       String
  role                UserRole           @default(learner)
  provider            Provider           @default(website)
  crm_customer_id     String?            @unique
  crm_mentor_id       String?            @unique
  subscription_status SubscriptionStatus @default(free)
  is_banned           Boolean            @default(false)
  bio                 String?            @db.Text
  phone               String?
  avatar_url          String?
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  memberships         Membership[]
  messages            Message[]          @relation("SenderMessages")
  batches_created     Batch[]            @relation("BatchCreator")
  channels_created    Channel[]          @relation("ChannelCreator")
  subscription        Subscription?
  admin_logs          AdminLog[]         @relation("ActorLogs")
  notifications       Notification[]
  pinned_messages     PinnedMessage[]
  mod_queue_reported  ModQueue[]         @relation("Reporter")
  mod_queue_reviewed  ModQueue[]         @relation("Reviewer")
  conversations_as_a  Conversation[]     @relation("ConvUserA")
  conversations_as_b  Conversation[]     @relation("ConvUserB")
  direct_messages     DirectMessage[]    @relation("DMSender")
  message_reactions   MessageReaction[]
  password_reset_tokens PasswordResetToken[]
  refresh_tokens        RefreshToken[]

  @@index([phone])            // login by phone lookup
  @@index([is_banned])        // DM users list filters on is_banned = false
  @@index([role])             // role-based queries (admin, mentor, learner)
  @@index([created_at(sort: Desc)]) // admin users pagination ordered newest first
  @@index([role, created_at(sort: Desc)]) // filtered admin users pagination
  @@map("users")
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique
  expires_at  DateTime
  used_at     DateTime?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique
  expires_at  DateTime
  revoked_at  DateTime?
  replaced_by String?   @db.Uuid
  user_agent  String?
  ip          String?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("refresh_tokens")
}

model Organization {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  slug       String   @unique
  created_at DateTime @default(now())

  batches Batch[]

  @@map("organizations")
}

model Batch {
  id          String    @id @default(uuid()) @db.Uuid
  org_id      String    @db.Uuid
  name        String
  description String?
  type        BatchType @default(general)
  is_paid     Boolean   @default(false)
  is_pinned   Boolean   @default(false)
  crm_batch_id String?   @unique
  crm_course   String?
  crm_course_id String?
  crm_start_date DateTime?
  crm_end_date DateTime?
  crm_active Boolean?
  crm_deleted Boolean?
  crm_batch_type String?
  crm_image String?
  crm_last_synced_at DateTime?
  created_by  String    @db.Uuid
  created_at  DateTime  @default(now())

  organization    Organization    @relation(fields: [org_id], references: [id])
  creator         User            @relation("BatchCreator", fields: [created_by], references: [id])
  batch_settings  BatchSettings?
  memberships     Membership[]
  channels        Channel[]

  @@map("batches")
}

model Channel {
  id         String   @id @default(uuid()) @db.Uuid
  batch_id   String   @db.Uuid
  name       String
  is_pinned  Boolean  @default(false)
  created_by String   @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  batch           Batch           @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  creator         User            @relation("ChannelCreator", fields: [created_by], references: [id])
  messages        Message[]
  pinned_messages PinnedMessage[]
  mod_queue       ModQueue[]
  message_sequence ChannelMessageSequence?

  @@index([batch_id])
  @@map("channels")
}

model ChannelMessageSequence {
  channel_id String @id @db.Uuid
  last_seq   Int    @default(0)

  channel Channel @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@map("channel_message_sequences")
}

model BatchSettings {
  id           String  @id @default(uuid()) @db.Uuid
  batch_id     String  @unique @db.Uuid
  allow_guests Boolean @default(false)
  max_members  Int?
  is_archived  Boolean @default(false)

  batch Batch @relation(fields: [batch_id], references: [id])

  @@map("batch_settings")
}

model Membership {
  id            String         @id @default(uuid()) @db.Uuid
  user_id       String         @db.Uuid
  batch_id      String         @db.Uuid
  role_in_batch MembershipRole @default(member)
  joined_at     DateTime       @default(now())

  user  User  @relation(fields: [user_id], references: [id])
  batch Batch @relation(fields: [batch_id], references: [id])

  @@unique([user_id, batch_id])
  @@index([batch_id, role_in_batch])  // mentor picker: WHERE batch_id IN (...) AND role_in_batch = mentor
  @@index([user_id])                  // memberships by user (batch list)
  @@map("memberships")
}

model Message {
  id           String      @id @default(uuid()) @db.Uuid
  channel_id   String      @db.Uuid
  sender_id    String      @db.Uuid
  content      String
  message_type MessageType @default(text)
  is_deleted   Boolean     @default(false)
  deleted_at   DateTime?
  parent_id    String?     @db.Uuid
  seq_id       Int
  created_at   DateTime    @default(now())

  channel     Channel             @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  sender      User                @relation("SenderMessages", fields: [sender_id], references: [id])
  parent      Message?            @relation("ThreadReplies", fields: [parent_id], references: [id])
  replies     Message[]           @relation("ThreadReplies")
  attachments MessageAttachment[]
  pinned      PinnedMessage[]
  mod_queue   ModQueue[]
  reactions   MessageReaction[]

  @@unique([channel_id, seq_id])
  @@index([channel_id, seq_id(sort: Desc)])
  @@map("messages")
}

model MessageAttachment {
  id         String @id @default(uuid()) @db.Uuid
  message_id String @db.Uuid
  file_url   String
  file_name  String
  file_size  Int
  mime_type  String

  message Message @relation(fields: [message_id], references: [id])

  @@map("message_attachments")
}

model Subscription {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @unique @db.Uuid
  plan       SubPlan   @default(free)
  status     SubStatus @default(active)
  started_at DateTime  @default(now())
  expires_at DateTime?

  user User @relation(fields: [user_id], references: [id])

  @@map("subscriptions")
}

model AdminLog {
  id          String   @id @default(uuid()) @db.Uuid
  actor_id    String   @db.Uuid
  target_id   String?  @db.Uuid
  action_type String
  metadata    Json?
  created_at  DateTime @default(now())

  actor User @relation("ActorLogs", fields: [actor_id], references: [id])

  @@map("admin_logs")
}

model Notification {
  id              String           @id @default(uuid()) @db.Uuid
  user_id         String           @db.Uuid
  sender_id       String?          @db.Uuid
  type            NotificationType
  ref_id          String?          @db.Uuid
  content_preview String?
  is_read         Boolean          @default(false)
  created_at      DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, is_read])   // unread notification count per user
  @@index([user_id, created_at(sort: Desc)])  // notifications list ordered by time
  @@map("notifications")
}

model PinnedMessage {
  id         String   @id @default(uuid()) @db.Uuid
  channel_id String   @db.Uuid
  message_id String   @db.Uuid
  pinned_by  String   @db.Uuid
  pinned_at  DateTime @default(now())

  channel Channel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  message Message @relation(fields: [message_id], references: [id])
  pinner  User    @relation(fields: [pinned_by], references: [id])

  @@map("pinned_messages")
}

model ModQueue {
  id          String           @id @default(uuid()) @db.Uuid
  channel_id  String           @db.Uuid
  message_id  String           @db.Uuid
  reported_by String           @db.Uuid
  status      ModQueueStatus   @default(pending)
  priority    ModQueuePriority @default(low)
  notes       String?
  reviewed_by String?          @db.Uuid
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  channel  Channel  @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  message  Message  @relation(fields: [message_id], references: [id])
  reporter User     @relation("Reporter", fields: [reported_by], references: [id])
  reviewer User?    @relation("Reviewer", fields: [reviewed_by], references: [id])

  @@map("mod_queue")
}

model Conversation {
  id         String   @id @default(uuid()) @db.Uuid
  user_a_id  String   @db.Uuid
  user_b_id  String   @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_a   User             @relation("ConvUserA", fields: [user_a_id], references: [id])
  user_b   User             @relation("ConvUserB", fields: [user_b_id], references: [id])
  messages DirectMessage[]
  message_sequence ConversationMessageSequence?

  @@unique([user_a_id, user_b_id])
  @@index([user_a_id, updated_at(sort: Desc)])  // conversations list for user_a
  @@index([user_b_id, updated_at(sort: Desc)])  // conversations list for user_b
  @@map("conversations")
}

model ConversationMessageSequence {
  conversation_id String @id @db.Uuid
  last_seq        Int    @default(0)

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("conversation_message_sequences")
}

model DirectMessage {
  id              String   @id @default(uuid()) @db.Uuid
  conversation_id String   @db.Uuid
  sender_id       String   @db.Uuid
  content         String
  is_read         Boolean  @default(false)
  seq_id          Int
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id])
  sender       User         @relation("DMSender", fields: [sender_id], references: [id])
  attachments  DirectMessageAttachment[]

  @@unique([conversation_id, seq_id])
  @@index([conversation_id, seq_id(sort: Desc)])      // message history ordered by deterministic sequence
  @@index([conversation_id, is_read])                  // unread count per conversation
  @@map("direct_messages")
}

model DirectMessageAttachment {
  id                String @id @default(uuid()) @db.Uuid
  direct_message_id String @db.Uuid
  file_url          String
  file_name         String
  file_size         Int
  mime_type         String

  message DirectMessage @relation(fields: [direct_message_id], references: [id])

  @@map("direct_message_attachments")
}

model MessageReaction {
  id         String   @id @default(uuid()) @db.Uuid
  message_id String   @db.Uuid
  user_id    String   @db.Uuid
  emoji      String
  created_at DateTime @default(now())

  message Message @relation(fields: [message_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id])

  @@unique([message_id, user_id, emoji])
  @@map("message_reactions")
}

// Transactional outbox: real-time events are written here in the SAME DB
// transaction as the domain row (message / DM). A relay publishes them to
// Socket.IO and marks them published. Guarantees an event is never lost even
// if the process crashes between the DB commit and the socket emit.
model OutboxEvent {
  id           BigInt    @id @default(autoincrement())
  aggregate    String    // 'channel' | 'dm' | 'notification'
  aggregate_id String    @db.Uuid // channelId | conversationId | userId — used for resync queries
  event        String    // socket event name, e.g. 'receive_message'
  rooms        String[]  // socket rooms to emit to, e.g. ['channel:abc'] or ['dm:x','user:y']
  payload      Json
  published    Boolean   @default(false)
  created_at   DateTime  @default(now())
  published_at DateTime?

  @@index([published, id])                  // relay: drain unpublished in order
  @@index([aggregate, aggregate_id, id])     // resync: events for a channel/conversation since cursor
  @@map("outbox_events")
}
