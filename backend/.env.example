DATABASE_URL=postgresql://user:pass@localhost:5432/chatapp
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=changeme_access
JWT_REFRESH_SECRET=changeme_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
UPLOAD_DIR=./uploads
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Refresh-cookie SameSite. When the CMS is embedded by the LMS on a different
# site, set this to "none" (forces Secure) so browsers that still allow it will
# send the cookie. The LMS-embed flow does not depend on it (the parent LMS
# re-supplies credentials), but set it for completeness. Defaults to "strict".
COOKIE_SAMESITE=strict

# LMS origin(s) allowed to embed CMS responses in an iframe (space/comma
# separated). Drives the `frame-ancestors` CSP header. Leave empty if the CMS
# is never framed.
FRAME_ANCESTORS=http://localhost:3000

# CRM Integration
CRM_INTEGRATION_KEY=your_random_secure_token_here

# CRM connection (used for provider="crm" login)
CRM_BASE_URL=http://localhost:4001
CRM_MENTOR_LOOKUP_BASE_URL=http://localhost:4001
CRM_INTERNAL_HMAC_SECRET=replace_with_same_secret_as_crm_backend
CRM_SERVICE_EMAIL=admin@yourcrm.com
CRM_SERVICE_PASSWORD=changeme
